<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        Pack themes (Light forms for dual-mode packs V3/V5; native form for
        single-mode dark packs V1/V2/V4 — those force MODE_NIGHT_YES at runtime
        so the night-qualified version below is what users actually see).

        Style names are stable across values/ and values-night/ folders:
            Theme.LiteGallery.Pack.<Pack>.NoActionBar
            Theme.LiteGallery.Pack.<Pack>.FullScreen
    -->

    <!-- =========================================================
         V3 · Warm Paper · Light
         ========================================================= -->
