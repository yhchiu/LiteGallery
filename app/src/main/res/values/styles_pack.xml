<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Pack-level shape and text appearance abstractions.

        FONTS: Bundled in res/font/ (all SIL OFL licensed):
            @font/fraunces            — Warm Paper (V3) variable serif
            @font/cormorant_garamond  — Editorial Noir (V1) family with italic
            @font/jetbrains_mono      — Monolith (V2) + Brutalist (V5) body
            @font/archivo_black       — Brutalist (V5) display
            V4 Prism uses sans-serif (system Roboto — Inter approximation).
    -->

    <!-- Shared shape used by the Media Viewer info sheet — rounded top, square bottom. -->
    <style name="ShapeAppearance.LiteGallery.InfoSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

